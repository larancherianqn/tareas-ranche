# Copiá este archivo como ".env" para desarrollo local.
# En Render, estas variables se cargan desde el panel (Environment), NO subas el .env real.

# Cadena de conexión a Postgres.
# En local podés usar algo como: postgres://usuario:clave@localhost:5432/tareas
# En Render se completa automáticamente con la base que crees (Internal Database URL).
DATABASE_URL=postgres://usuario:clave@localhost:5432/tareas

# Clave para firmar las sesiones. Poné un texto largo y aleatorio.
SESSION_SECRET=cambia-esto-por-un-texto-largo-y-aleatorio

# Credenciales de Google OAuth (las sacás de Google Cloud Console).
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret

# URL pública de la app (sin barra al final).
# En local: http://localhost:3000
# En Render: https://nombre-de-tu-app.onrender.com
BASE_URL=http://localhost:3000

# Tu correo de Gmail. Quien entre con este correo será administrador.
ADMIN_EMAIL=tucorreo@gmail.com

# Zona horaria para los eventos del calendario.
APP_TIMEZONE=America/Argentina/Buenos_Aires

# Puerto local (Render lo asigna solo, no hace falta tocarlo allá).
PORT=3000

# Notificaciones por mail (opcional). Para avisar al equipo cuando se publica un aviso.
# Usar una "contraseña de aplicación" de Gmail (16 caracteres), no la contraseña normal.
MAIL_USER=tucorreo@gmail.com
MAIL_PASS=xxxxxxxxxxxxxxxx
MAIL_FROM=Tareas <tucorreo@gmail.com>
