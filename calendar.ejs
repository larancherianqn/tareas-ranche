<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ingresar · Tareas</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,700;12..96,800&family=Inter:wght@400;500;600&family=Space+Mono:wght@400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <div class="login-wrap">
    <div class="login-card">
      <span class="brand-mark" aria-hidden="true"></span>
      <h1>Tareas</h1>
      <p>Control y seguimiento del trabajo del equipo.</p>

      <% if (typeof flash !== 'undefined' && flash) { %>
        <div class="flash flash-<%= flash.type %>"><%= flash.text %></div>
      <% } %>

      <a class="btn btn-google" href="/auth/google">
        Ingresar con Google
      </a>
      <p class="fine">Solo pueden entrar los correos autorizados por el administrador.</p>
    </div>
  </div>
</body>
</html>
