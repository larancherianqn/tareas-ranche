<%- include('partials/head') %>

<div class="page-head">
  <div>
    <p class="eyebrow"><a class="back-link" href="/buzon">← Volver al buzón</a></p>
    <h1>Nuevo aviso</h1>
  </div>
</div>

<div class="card">
  <form method="POST" action="/avisos" enctype="multipart/form-data" class="form-grid">
    <div class="field">
      <label for="title">Título</label>
      <input type="text" id="title" name="title" required maxlength="200" placeholder="Ej: Cronograma de julio" />
    </div>

    <div class="row-2">
      <div class="field">
        <label for="kind">Tipo</label>
        <select id="kind" name="kind">
          <% types.forEach(function (t) { %>
            <option value="<%= t.name %>"><%= t.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="field">
        <label for="ref_date">Fecha relacionada (opcional)</label>
        <input type="date" id="ref_date" name="ref_date" />
        <p class="muted" style="font-size:12px; margin:6px 0 0;">Útil para "día no laborable".</p>
      </div>
    </div>

    <div class="field">
      <label>Para</label>
      <% if (employees.length === 0) { %>
        <p class="muted" style="font-size:14px; margin:4px 0 0;">Va a todo el equipo. (Cargá empleados en Equipo para poder dirigir avisos a personas puntuales.)</p>
      <% } else { %>
        <div style="display:flex; flex-direction:column; gap:8px; border:1px solid var(--line); border-radius:12px; padding:12px;">
          <% employees.forEach(function (e) { %>
            <label style="display:flex; align-items:center; gap:8px; text-transform:none; letter-spacing:0; font-family:var(--font-body); font-size:15px; color:var(--ink);">
              <input type="checkbox" name="target_employees" value="<%= e.id %>" />
              <%= e.name %>
            </label>
          <% }) %>
        </div>
        <p class="muted" style="font-size:13px; margin:6px 0 0;">Marcá uno o varios. Si no marcás ninguno, el aviso va a <strong>todo el equipo</strong>. Si marcás un solo empleado, sus archivos quedan en el legajo de esa persona en Drive.</p>
      <% } %>
    </div>

    <div class="field">
      <label for="body">Mensaje</label>
      <textarea id="body" name="body" placeholder="Escribí el aviso (opcional)"></textarea>
    </div>

    <div class="field">
      <label for="files">Adjuntos</label>
      <input type="file" id="files" name="files" multiple />
      <p class="muted" style="font-size:13px; margin:6px 0 0;">PDF, imágenes, Word, etc. Hasta 5 archivos, máximo 10 MB cada uno.</p>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn">Publicar aviso</button>
      <a class="btn-ghost" href="/buzon">Cancelar</a>
    </div>
  </form>
</div>

<%- include('partials/foot') %>
