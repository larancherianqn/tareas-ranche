<%- include('partials/head') %>

<div class="page-head">
  <div>
    <p class="eyebrow"><a class="back-link" href="/buzon">← Volver al buzón</a></p>
    <h1><%= h.requestKindLabel(request.kind) %></h1>
  </div>
  <span class="pill" data-r="<%= request.status %>"><%= h.requestStatusLabel(request.status) %></span>
</div>

<div class="card">
  <dl class="meta-grid">
    <div>
      <dt>Solicitante</dt>
      <dd><%= request.requester_name || request.requester_email || '—' %></dd>
    </div>
    <div>
      <dt>Empleado</dt>
      <dd><%= request.employee_name || '—' %></dd>
    </div>
    <div>
      <dt>Desde</dt>
      <dd><%= h.formatDate(request.start_date) %></dd>
    </div>
    <div>
      <dt>Hasta</dt>
      <dd><%= h.formatDate(request.end_date) %></dd>
    </div>
    <div>
      <dt>Enviada</dt>
      <dd><%= h.formatDate(request.created_at) %></dd>
    </div>
  </dl>

  <% if (request.reason) { %>
    <div style="margin-top:18px;">
      <dt class="eyebrow" style="margin-bottom:6px;">Motivo</dt>
      <p class="desc"><%= request.reason %></p>
    </div>
  <% } %>

  <% if (request.admin_note) { %>
    <div style="margin-top:18px;">
      <dt class="eyebrow" style="margin-bottom:6px;">Respuesta del administrador</dt>
      <p class="desc"><%= request.admin_note %></p>
      <% if (request.reviewer_name) { %>
        <p class="muted" style="font-size:13px; margin-top:6px;"><%= request.reviewer_name %> · <%= h.formatDateTime(request.reviewed_at) %></p>
      <% } %>
    </div>
  <% } %>
</div>

<% if (files.length > 0) { %>
  <div class="card">
    <h2>Adjuntos</h2>
    <ul class="files">
      <% files.forEach(function (f) { %>
        <li>
          <a href="/attachments/<%= f.id %>" target="_blank" rel="noopener">📎 <%= f.filename %></a>
          <span class="muted"><%= h.fileSize(f.size_bytes) %></span>
        </li>
      <% }) %>
    </ul>
  </div>
<% } %>

<% if (isAdmin) { %>
  <div class="card">
    <h2>Resolver solicitud</h2>
    <form method="POST" action="/solicitudes/<%= request.id %>/status" class="form-grid">
      <div class="field">
        <label for="status">Estado</label>
        <select id="status" name="status">
          <% h.REQUEST_STATUSES.forEach(function (s) { %>
            <option value="<%= s.value %>" <%= request.status === s.value ? 'selected' : '' %>><%= s.label %></option>
          <% }) %>
        </select>
      </div>
      <div class="field">
        <label for="admin_note">Comentario (opcional)</label>
        <textarea id="admin_note" name="admin_note" placeholder="Ej: Aprobada, que te mejores."><%= request.admin_note || '' %></textarea>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn">Guardar</button>
      </div>
    </form>
  </div>
<% } else { %>
  <form method="POST" action="/solicitudes/<%= request.id %>?_method=DELETE" class="inline"
        onsubmit="return confirm('¿Eliminar esta solicitud?');">
    <button type="submit" class="btn-danger btn-sm">Eliminar solicitud</button>
  </form>
<% } %>

<%- include('partials/foot') %>
