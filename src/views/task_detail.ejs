<%- include('partials/head') %>

<% var d = h.daysUntil(task.due_date); %>

<div class="page-head">
  <div>
    <p class="eyebrow"><a class="back-link" href="/">← Volver a tareas</a></p>
    <h1><%= task.title %></h1>
  </div>
  <% if (isAdmin) { %>
    <div style="display:flex; gap:8px;">
      <a class="btn-ghost btn-sm" href="/tasks/<%= task.id %>/edit">Editar</a>
      <form method="POST" action="/tasks/<%= task.id %>?_method=DELETE" class="inline"
            onsubmit="return confirm('¿Eliminar esta tarea y todo su historial?');">
        <button type="submit" class="btn-danger btn-sm">Eliminar</button>
      </form>
    </div>
  <% } %>
</div>

<div class="card">
  <dl class="meta-grid">
    <div>
      <dt>Estado</dt>
      <dd><span class="pill" data-s="<%= task.status %>"><%= h.statusLabel(task.status) %></span></dd>
    </div>
    <div>
      <dt>Tipo</dt>
      <dd><%= task.category ? h.categoryLabel(task.category) : '—' %></dd>
    </div>
    <div>
      <dt>Responsable</dt>
      <dd><%= task.assignee_name || 'Sin asignar' %></dd>
    </div>
    <div>
      <dt>Sector</dt>
      <dd><%= task.sector_name || '—' %></dd>
    </div>
    <div>
      <dt>Vence</dt>
      <dd class="<%= (d !== null && d < 0 && task.status !== 'hecha') ? 'due is-late' : '' %>">
        <%= h.formatDate(task.due_date) %><% if (task.due_date && task.status !== 'hecha' && d < 0) { %> · vencida<% } %>
      </dd>
    </div>
    <div>
      <dt>Creada por</dt>
      <dd><%= task.creator_name || '—' %><br><span class="muted" style="font-size:13px;"><%= h.formatDateTime(task.created_at) %></span></dd>
    </div>
  </dl>

  <% if (task.description) { %>
    <div style="margin-top:20px;">
      <dt class="eyebrow" style="margin-bottom:6px;">Descripción</dt>
      <p class="desc"><%= task.description %></p>
    </div>
  <% } %>
</div>

<% if (files && files.length > 0) { %>
  <div class="card">
    <h2>Foto de referencia</h2>
    <div class="photo-grid">
      <% files.forEach(function (f) { %>
        <% if (f.mime_type && f.mime_type.indexOf('image/') === 0) { %>
          <a href="/attachments/<%= f.id %>" target="_blank" rel="noopener" class="photo-view">
            <img src="/attachments/<%= f.id %>" alt="<%= f.filename %>" />
          </a>
        <% } else { %>
          <a href="/attachments/<%= f.id %>" target="_blank" rel="noopener">📎 <%= f.filename %></a>
        <% } %>
      <% }) %>
    </div>
  </div>
<% } %>

<div class="card">
  <h2>Registrar avance</h2>
  <form method="POST" action="/tasks/<%= task.id %>/update" class="form-grid">
    <div class="field">
      <label for="status">Estado</label>
      <select id="status" name="status">
        <% h.STATUSES.forEach(function (s) { %>
          <option value="<%= s.value %>" <%= task.status === s.value ? 'selected' : '' %>><%= s.label %></option>
        <% }) %>
      </select>
    </div>
    <div class="field">
      <label for="note">Observación</label>
      <textarea id="note" name="note" placeholder="¿Qué se hizo? ¿Qué falta? (opcional si solo cambiás el estado)"></textarea>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn">Guardar avance</button>
    </div>
  </form>
</div>

<div class="card">
  <h2>Historial</h2>
  <% if (updates.length === 0) { %>
    <p class="muted">Todavía no hay avances registrados.</p>
  <% } else { %>
    <ul class="timeline">
      <% updates.forEach(function (u) { %>
        <li data-s="<%= u.status %>">
          <span class="dot" aria-hidden="true"></span>
          <div class="line-head">
            <span class="who"><%= u.author_name || 'Alguien' %></span>
            <span class="pill" data-s="<%= u.status %>"><%= h.statusLabel(u.status) %></span>
            <span class="when"><%= h.formatDateTime(u.created_at) %></span>
          </div>
          <% if (u.note) { %><p class="note"><%= u.note %></p><% } %>
        </li>
      <% }) %>
    </ul>
  <% } %>
</div>

<%- include('partials/foot') %>
