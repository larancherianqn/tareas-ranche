<%- include('partials/head') %>

<% var editing = !!task; %>
<div class="page-head">
  <div>
    <p class="eyebrow"><a class="back-link" href="<%= editing ? '/tasks/' + task.id : '/' %>">← Volver</a></p>
    <h1><%= editing ? 'Editar tarea' : 'Nueva tarea' %></h1>
  </div>
</div>

<div class="card">
  <form method="POST" action="<%= editing ? '/tasks/' + task.id + '?_method=PUT' : '/tasks' %>" enctype="multipart/form-data" class="form-grid">
    <div class="field">
      <label for="title">Título</label>
      <input type="text" id="title" name="title" required maxlength="200"
             value="<%= editing ? task.title : '' %>" placeholder="Ej: Llamar al proveedor" />
    </div>

    <div class="field">
      <label for="description">Descripción</label>
      <textarea id="description" name="description" placeholder="Detalle de lo que hay que hacer (opcional)"><%= editing ? (task.description || '') : '' %></textarea>
    </div>

    <div class="row-2">
      <div class="field">
        <label for="assigned_to">Responsable (persona)</label>
        <select id="assigned_to" name="assigned_to">
          <option value="">Sin asignar</option>
          <% users.forEach(function (u) { %>
            <option value="<%= u.id %>" <%= (editing && task.assigned_to === u.id) ? 'selected' : '' %>>
              <%= u.name || u.email %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="field">
        <label for="sector_id">Sector responsable</label>
        <select id="sector_id" name="sector_id">
          <option value="">Sin sector</option>
          <% sectors.forEach(function (s) { %>
            <option value="<%= s.id %>" <%= (editing && task.sector_id === s.id) ? 'selected' : '' %>>
              <%= s.name %>
            </option>
          <% }) %>
        </select>
      </div>
    </div>

    <div class="row-2">
      <div class="field">
        <label for="due_date">Fecha de vencimiento</label>
        <input type="date" id="due_date" name="due_date"
               value="<%= editing ? h.toInputDate(task.due_date) : '' %>" />
      </div>
      <div class="field"></div>
    </div>

    <div class="row-2">
      <div class="field">
        <label for="category">Tipo de tarea</label>
        <select id="category" name="category">
          <option value="">Sin tipo</option>
          <% h.CATEGORIES.forEach(function (c) { %>
            <option value="<%= c.value %>" <%= (editing && task.category === c.value) ? 'selected' : '' %>>
              <%= c.label %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="field">
        <label for="status">Estado</label>
        <select id="status" name="status">
          <% h.STATUSES.forEach(function (s) { %>
            <option value="<%= s.value %>" <%= (editing ? task.status === s.value : s.value === 'pendiente') ? 'selected' : '' %>>
              <%= s.label %>
            </option>
          <% }) %>
        </select>
      </div>
    </div>

    <div class="field">
      <label style="display:flex; align-items:center; gap:10px; text-transform:none; letter-spacing:0; font-family:var(--font-body); font-size:15px; color:var(--ink);">
        <input type="checkbox" id="urgent" name="urgent" <%= (editing && task.urgent) ? 'checked' : '' %> />
        Marcar como <strong>urgente</strong>
      </label>
      <p class="muted" style="font-size:13px; margin:6px 0 0;">Las tareas urgentes aparecen primero en el listado y con un cartel rojo.</p>
    </div>

    <div class="field">
      <label for="files">Foto de referencia (opcional)</label>
      <input type="file" id="files" name="files" accept="image/*" multiple />
      <p class="muted" style="font-size:13px; margin:6px 0 0;">Una imagen que muestre cómo debe quedar / qué hay que hacer. Podés subir más de una.</p>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn"><%= editing ? 'Guardar cambios' : 'Crear tarea' %></button>
      <a class="btn-ghost" href="<%= editing ? '/tasks/' + task.id : '/' %>">Cancelar</a>
    </div>
  </form>
</div>

<% if (editing && files.length > 0) { %>
  <div class="card">
    <h2>Fotos actuales</h2>
    <div class="photo-grid">
      <% files.forEach(function (f) { %>
        <div class="photo-item">
          <% if (f.mime_type && f.mime_type.indexOf('image/') === 0) { %>
            <a href="/attachments/<%= f.id %>" target="_blank" rel="noopener"><img src="/attachments/<%= f.id %>" alt="<%= f.filename %>" /></a>
          <% } else { %>
            <a href="/attachments/<%= f.id %>" target="_blank" rel="noopener">📎 <%= f.filename %></a>
          <% } %>
          <form method="POST" action="/attachments/<%= f.id %>?_method=DELETE" onsubmit="return confirm('¿Quitar esta foto?');">
            <button type="submit" class="btn-ghost btn-sm">Quitar</button>
          </form>
        </div>
      <% }) %>
    </div>
  </div>
<% } %>

<% if (users.length === 0) { %>
  <p class="muted">Todavía no hay personas que hayan ingresado para asignarles tareas. Autorizá correos en <a href="/admin/users">Equipo</a>; aparecerán acá una vez que entren por primera vez.</p>
<% } %>

<% if (sectors.length === 0) { %>
  <p class="muted">Todavía no creaste sectores. Podés crearlos en <a href="/admin/users">Equipo</a> y después asignarlos acá.</p>
<% } %>

<%- include('partials/foot') %>
